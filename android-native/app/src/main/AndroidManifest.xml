<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Bluetooth Permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_BACKGROUND" />

    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- INTERNET: required for optional OUI database updates from GitHub -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- POST_NOTIFICATIONS is required on Android 13+ (API 33+) for threat alerts -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- NEARBY_WIFI_DEVICES is required on Android 13+ (API 33+) to call startScan() -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <!-- Mandatory for Biometric Locking on Android 11+ (KI-014: removing this causes silent crash) -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Required for background scanning service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--
        Signature-level IPC permission — OWASP MASVS IPC hardening.
        Only components signed with the same certificate as WiFiSentry can
        bind to or start exported services.  This prevents third-party apps
        from injecting data into the scan pipeline.
    -->
    <permission
        android:name="com.wifisentry.app.BIND_SCAN_SERVICE"
        android:protectionLevel="signature" />

    <uses-feature
        android:name="android.hardware.wifi"
        android:required="true" />

    <application
        android:name=".WifiSentryApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WifiSentry"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:label="Setup WiFi Sentry"
            android:theme="@style/Theme.WifiSentry" />

        <activity
            android:name=".HistoryActivity"
            android:exported="false"
            android:label="@string/title_history"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ImportActivity"
            android:exported="false"
            android:label="@string/import_title"
            android:parentActivityName=".HistoryActivity" />

        <activity
            android:name=".PinDetailActivity"
            android:exported="false"
            android:label="@string/title_pin_detail"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".DynamicUiActivity"
            android:exported="false"
            android:label="Dynamic Dashboard"
            android:theme="@style/Theme.WifiSentry"
            android:parentActivityName=".MainActivity" />

        <!-- Compose-based network dashboard -->
        <activity
            android:name=".ComposeDashboardActivity"
            android:exported="false"
            android:label="Network Dashboard"
            android:theme="@style/Theme.WifiSentry"
            android:parentActivityName=".MainActivity" />

        <!--
            Shizuku provider — required for Shizuku API integration.
            This provider supplies the Shizuku Binder to the app when the
            Shizuku service is running.  It is NOT exported to other apps.
        -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="rikka.shizuku.ShizukuProvider.PERMISSION" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>
</manifest>
