{
  "name": "wifi-sentry",
  "version": "1.2.8",
  "description": "A WiFi monitoring and security application that detects evil twins, karma attacks, WiFi pineapples, and emerging WiFi spoofing techniques.",
  "main": "server.js",
  "scripts": {
    "preinstall": "node scripts/check-node-version.js",
    "setup": "node scripts/setup.js",
    "setup:prod": "node scripts/setup.js --prod",
    "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\"",
    "dev:all": "concurrently \"npm start\" \"npm run web:dev\"",
    "dev:back": "npm run dev:backend",
    "dev:backend": "nodemon server.js",
    "dev:front": "npm run web:dev",
    "start": "node server.js",
    "build": "npm run build:all",
    "build:all": "npm run web:build && npm run desktop:build",
    "test": "jest --detectOpenHandles",
    "lint": "eslint . --fix",
    "web:dev": "cd web-app && npm run dev",
    "web:build": "cd web-app && npm run build",
    "desktop:dev": "electron desktop/main.js",
    "desktop:build-web": "npm run web:build",
    "desktop:build": "electron-builder --publish never",
    "desktop:build-win": "npm run desktop:build",
    "mobile:compile": "cd android-native && ./gradlew assembleRelease && cd ..",
    "verify-services": "node verify-services.js",
    "validate-env": "node utils/validate-env.js MONGODB_URI_TEST",
    "test:integration": "node -e \"const fs=require('fs'); if (!fs.existsSync('test/integration')) { console.log('No integration tests configured'); process.exit(0); } console.error('No integration test runner configured for test/integration'); process.exit(1);\""
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/session": "11.1.1",
    "@fastify/static": "9.0.0",
    "@fastify/websocket": "11.2.0",
    "@google/generative-ai": "0.24.1",
    "axios": "1.13.6",
    "dotenv": "17.3.1",
    "electron-updater": "6.8.3",
    "fastify": "5.8.2",
    "iw": "0.0.1",
    "joi": "18.0.2",
    "mongoose": "9.2.4",
    "next": "16.1.6",
    "node-wifi": "2.0.16",
    "otplib": "13.3.0",
    "pino-pretty": "13.1.3",
    "qrcode": "1.5.4",
    "tcpdump": "0.0.1",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "concurrently": "9.2.1",
    "electron": "35.7.5",
    "electron-builder": "26.8.1",
    "eslint": "9.39.4",
    "globals": "17.4.0",
    "jest": "30.2.0",
    "nodemon": "3.1.14",
    "typescript": "5.9.3"
  },
  "electron-builder": {
    "appId": "com.wifisentry.app",
    "productName": "WiFi Sentry",
    "files": [
      "desktop/main.js",
      "desktop/preload.js",
      "desktop/assets/**/*",
      "node_modules/**/*",
      "server.js",
      "*.js",
      "*.json",
      {
        "from": "web-app/out",
        "to": "web-app/out",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "desktop/assets",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WiFi Sentry"
    }
  },
  "author": "WiFi Sentry Team",
  "license": "MIT",
  "keywords": [
    "wifi-security",
    "threat-detection",
    "evil-twin",
    "karma-attack",
    "wifi-pineapple",
    "ai-research",
    "cross-platform",
    "electron",
    "pwa"
  ]
}
